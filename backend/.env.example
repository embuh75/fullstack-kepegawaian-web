# Url Mysql & Pengaturan Projek
DATABASE_URL=mysql://root:@127.0.0.1:3306/db_kepegawaian
PORT=3000
NODE_ENV=development
# Token Auth
JWT_SECRET=ganti_dengan_secret_key_yang_kuat_minimal_32_karakter
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=ganti_dengan_refresh_secret_yang_berbeda_minimal_32_karakter
JWT_REFRESH_EXPIRES_IN=7d
# Ganti dengan nama domain jika sudah dideploy
APP_URL=http://localhost:3000 
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001
# Atur Limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100